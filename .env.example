# Firebase Web App config (Firebase Console > Project settings > General > Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=run213.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=run213
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=run213.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: document-only for now. Do not initialize Firebase Analytics yet.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK service account (server only; never expose to the browser)
FIREBASE_PROJECT_ID=run213
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin allowlists for future admin protection
ADMIN_EMAILS=
SUPER_ADMIN_EMAIL=
