rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Phase 1 admin authorization uses Firebase Auth custom claims.
    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isOwnEmail(email) {
      return signedIn()
        && request.auth.token.email != null
        && email == request.auth.token.email;
    }

    function isPublicCatalogProduct() {
      return resource.data.status == "active" || !("status" in resource.data);
    }

    function validUserProfileCreate(uid) {
      return isOwner(uid)
        && request.resource.data.keys().hasOnly([
          "orderCount",
          "loyaltyRewardAvailable",
          "loyaltyRewardPercent",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.orderCount is int
        && request.resource.data.orderCount >= 0
        && request.resource.data.loyaltyRewardAvailable is bool
        && request.resource.data.loyaltyRewardPercent is int
        && request.resource.data.loyaltyRewardPercent >= 0
        && request.resource.data.loyaltyRewardPercent <= 50;
    }

    function validOwnerDocument(uid) {
      return isOwner(uid)
        && (!("uid" in request.resource.data) || request.resource.data.uid == uid)
        && (!("userId" in request.resource.data) || request.resource.data.userId == uid);
    }

    match /products/{id} {
      allow read: if isAdmin() || isPublicCatalogProduct();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /designThemes/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /adminStats/{id} {
      allow read, write: if isAdmin();
    }

    match /adminStatsDaily/{id} {
      allow read, write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if validUserProfileCreate(uid);
      allow update: if isAdmin()
        || (
          isOwner(uid)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["updatedAt"])
        );
      allow delete: if isAdmin();
    }

    match /favorites/{uid} {
      allow read, delete: if isOwner(uid) || isAdmin();
      allow create, update: if isAdmin() || validOwnerDocument(uid);
    }

    // The current wishlist collection stores email signups via /api/wishlist.
    // Direct client access is limited to admin or owner-shaped user documents.
    match /wishlist/{uid} {
      allow read, delete: if isOwner(uid) || isAdmin();
      allow create, update: if isAdmin() || validOwnerDocument(uid);
    }

    match /orders/{id} {
      allow create: if isAdmin();
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || isOwnEmail(resource.data.customerEmail);
      allow update, delete: if isAdmin();
    }

    match /contactMessages/{id} {
      allow read, create, update, delete: if isAdmin();
    }
  }
}
